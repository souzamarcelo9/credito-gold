# Copie este arquivo para .env.local e preencha os valores

NEXT_PUBLIC_BASE_URL=https://seudominio.com.br
NEXTAUTH_URL=https://seudominio.com.br
NEXTAUTH_SECRET=gere-um-secret-forte-com-openssl-rand-base64-32

# Cloud SQL (PostgreSQL ou MySQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/creditogold"

# WhatsApp Z-API
ZAPI_INSTANCE_ID=sua-instancia
ZAPI_TOKEN=seu-token

# E-mail Resend
RESEND_API_KEY=re_xxxxxxxxxxxxx

# PIX Asaas
ASAAS_API_KEY=sua-chave-asaas

# Google Cloud Storage
GCS_BUCKET_NAME=creditogold-docs
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
