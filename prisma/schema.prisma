generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")  
}

// ─────────────────────────────────────────────
// USUÁRIOS E AUTENTICAÇÃO
// ─────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  password  String
  role      Role     @default(CLIENTE)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  afiliado  Afiliado?
  auditLogs AuditLog[]

  @@map("users")
}

enum Role {
  ADMIN
  FINANCEIRO
  AFILIADO
  CLIENTE
}

// ─────────────────────────────────────────────
// AFILIADOS
// ─────────────────────────────────────────────
model Afiliado {
  id               String         @id @default(cuid())
  nome             String
  cpf              String         @unique
  cpfHash          String         // hash para busca sem expor o CPF
  telefone         String
  email            String?
  slug             String         @unique
  status           AfiliadoStatus @default(PENDENTE)
  nivel            AfiliadoNivel  @default(BRONZE)
  codigoIndicacao  String?
  totalCliques     Int            @default(0)
  totalLeads       Int            @default(0)
  totalAprovados   Int            @default(0)
  totalComissoes   Float          @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  leads     Lead[]
  comissoes Comissao[]

  @@map("afiliados")
}

enum AfiliadoStatus {
  PENDENTE
  ATIVO
  INATIVO
}

enum AfiliadoNivel {
  BRONZE
  PRATA
  GOLD
  DIAMANTE
}

// ─────────────────────────────────────────────
// LEADS
// ─────────────────────────────────────────────
model Lead {
  id            String      @id @default(cuid())
  nome          String
  email         String      @default("")
  cpf           String      // criptografado em repouso
  cpfHash       String      // hash SHA256 para deduplicação
  telefone      String
  produto       Produto
  valor         Float
  parcelas      Int         @default(0)
  parcelaMensal Float       @default(0)
  cidade        String?
  estado        String?
  status        LeadStatus  @default(NOVO)
  origem        Origem      @default(ORGANICO)
  observacoes   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  afiliadoId  String?
  afiliado    Afiliado?    @relation(fields: [afiliadoId], references: [id])
  comissao    Comissao?
  documentos  Documento[]
  dadosEnergia     LeadEnergia?
  correspondente   LeadCorrespondente?
  bancoId          String?
  banco            BancoPromotora? @relation("LeadBanco", fields: [bancoId], references: [id])

  @@index([cpfHash])
  @@index([status])
  @@index([produto])
  @@index([afiliadoId])
  @@index([createdAt])
  @@map("leads")
}

// Dados complementares preenchidos pelo correspondente
model LeadEnergia {
  id                  String   @id @default(cuid())
  concessionaria      String?
  numeroInstalacao    String?
  numeroCliente       String?
  titularConta        String?
  cpfTitular          String?
  valorMedioFatura    Float?
  possuiDebitos       Boolean  @default(false)
  dataVencimento      String?
  observacoesInternas String?
  preenchidoPor       String?  // userId do operador
  preenchidoEm        DateTime @default(now())
  updatedAt           DateTime @updatedAt

  leadId String @unique
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("leads_energia")
}

enum LeadStatus {
  NOVO
  EM_ANALISE
  PROPOSTA_ENVIADA
  CONTRATO_ASSINADO
  APROVADO
  RECUSADO
}

enum Produto {
  PESSOAL
  GARANTIA
  EMPRESARIAL
  CONSIGNADO
  FGTS
  ENERGIA
}


enum Origem {
  ORGANICO
  AFILIADO
  WHATSAPP
  DIRETO
}

// ─────────────────────────────────────────────
// COMISSÕES
// ─────────────────────────────────────────────
model Comissao {
  id          String          @id @default(cuid())
  valor       Float
  status      ComissaoStatus  @default(PENDENTE)
  pixChave    String?         // chave PIX do afiliado no momento do pagamento
  paidAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  leadId     String    @unique
  lead       Lead      @relation(fields: [leadId], references: [id])
  afiliadoId String
  afiliado   Afiliado  @relation(fields: [afiliadoId], references: [id])

  @@index([afiliadoId])
  @@index([status])
  @@map("comissoes")
}

enum ComissaoStatus {
  PENDENTE
  PAGO
  CANCELADO
}

// ─────────────────────────────────────────────
// DOCUMENTOS
// ─────────────────────────────────────────────
model Documento {
  id          String   @id @default(cuid())
  nome        String
  tipo        String   // CNH, comprovante_renda, etc.
  url         String   // URL privada no Cloud Storage
  tamanhoKb   Int
  mimeType    String
  uploadadoPor String  // userId de quem fez upload
  createdAt   DateTime @default(now())

  leadId  String
  lead    Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("documentos")
}

// ─────────────────────────────────────────────
// AUDIT LOG (LGPD + Auditoria Bancária)
// ─────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  action      String   // ex: LEAD_CREATED, LOGIN_FAILED
  severity    String   @default("info") // info | warning | critical
  userId      String?
  userEmail   String?
  userRole    String?
  targetId    String?
  targetType  String?
  ipAddress   String
  userAgent   String?
  details     Json?    // dados extras sem informações sensíveis
  success     Boolean  @default(true)
  errorMsg    String?
  createdAt   DateTime @default(now())

  user  User?  @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([userId])
  @@index([severity])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// CONFIGURAÇÕES DO SISTEMA
// ─────────────────────────────────────────────
model Config {
  id        String   @id @default(cuid())
  chave     String   @unique
  valor     String
  descricao String?
  updatedAt DateTime @updatedAt

  @@map("configs")
}

// ─────────────────────────────────────────────
// CORRESPONDENTES (distribuição de leads)
// ─────────────────────────────────────────────
model Correspondente {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  telefone  String
  ativo     Boolean  @default(true)
  totalLeads Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads LeadCorrespondente[]

  @@map("correspondentes")
}

model LeadCorrespondente {
  id               String   @id @default(cuid())
  distribuidoEm    DateTime @default(now())

  leadId           String   @unique
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  correspondenteId String
  correspondente   Correspondente @relation(fields: [correspondenteId], references: [id])

  @@index([correspondenteId])
  @@map("lead_correspondentes")
}

// ─────────────────────────────────────────────
// BANCOS E PROMOTORAS
// ─────────────────────────────────────────────
model BancoPromotora {
  id     String              @id @default(cuid())
  nome   String
  tipo   TipoBanco           @default(BANCO)
  ativo  Boolean             @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  produtos ProdutoBanco[]
  leads    Lead[]            @relation("LeadBanco")

  @@map("bancos_promotoras")
}

enum TipoBanco {
  BANCO
  PROMOTORA
}

model ProdutoBanco {
  id                  String   @id @default(cuid())
  produto             Produto
  comissaoCG          Float    // % que a Crédito Gold recebe do banco
  percentualAfiliado  Float    // % da comissão CG repassada ao afiliado
  percentualCorrespondente Float // % da comissão CG repassada ao correspondente
  ativo               Boolean  @default(true)
  updatedAt           DateTime @updatedAt

  bancoId String
  banco   BancoPromotora @relation(fields: [bancoId], references: [id], onDelete: Cascade)

  @@unique([bancoId, produto])
  @@map("produtos_banco")
}

// ─────────────────────────────────────────────
// DESPESAS OPERACIONAIS
// ─────────────────────────────────────────────
model Despesa {
  id              String           @id @default(cuid())
  descricao       String
  categoria       CategoriaDespesa @default(OPERACIONAL)
  valor           Float            // valor total
  parcelado       Boolean          @default(false)
  totalParcelas   Int              @default(1)
  parcelaAtual    Int              @default(1)
  valorParcela    Float?           // calculado: valor / totalParcelas
  dataPrimeiraParcela DateTime?
  formaPagamento  String           @default("À vista")
  data            DateTime         @default(now())
  observacao      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([data])
  @@map("despesas")
}

enum CategoriaDespesa {
  OPERACIONAL
  PESSOAL
  MARKETING
  TECNOLOGIA
  JURIDICO
  IMPOSTOS
  OUTROS
}

// ─────────────────────────────────────────────
// CONTROLE DE DOCUMENTOS
// ─────────────────────────────────────────────
model DocumentoInterno {
  id           String              @id @default(cuid())
  titulo       String
  categoria    CategoriaDocumento  @default(EMPRESA)
  descricao    String?
  arquivoUrl   String?             // URL do arquivo no Storage
  arquivoNome  String?
  responsavel  String?
  dataEmissao  DateTime?
  dataVencimento DateTime?
  status       StatusDocumento     @default(VALIDO)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([status])
  @@index([dataVencimento])
  @@index([categoria])
  @@map("documentos_internos")
}

enum CategoriaDocumento {
  EMPRESA
  CORRESPONDENTE
  AFILIADO
  BANCO_PARCEIRO
  JURIDICO
  CONTABIL
  OUTROS
}

enum StatusDocumento {
  VALIDO
  VENCENDO    // vence em até 30 dias
  VENCIDO
  ARQUIVADO
}
